# ══════════════════════════════════════════════════════════════════
#  NLTC BACKEND — .gitignore
# ══════════════════════════════════════════════════════════════════

# ── Secrets & credentials ─────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*-service-account*.json
serviceAccount*.json
firebase-adminsdk*.json

# ── Dependencies ──────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────
dist/
build/

# ── Logs ──────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Runtime & OS ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pid
*.seed
*.pid.lock

# ── Test & coverage ───────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Editor & IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.history/

# ── Render / hosting artifacts ────────────────────────────────────
.render-buildpacks.json